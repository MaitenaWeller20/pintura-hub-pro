# ---- Facturación electrónica AFIP/ARCA ----
# Cifra el certificado y la clave privada en la base (AES-256-GCM).
# NO SE ROTA: si la perdés, el certificado guardado queda indescifrable y hay
# que rehacer todo el trámite del CSR con AFIP.
ARCA_ENCRYPTION_KEY=""

# true  -> CAE simulado, no se llama a AFIP (para operar y demostrar sin certificado)
# false -> se llama a AFIP de verdad (homologación o producción, según el punto de venta)
INVOICING_MOCK_MODE="true"

